{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lanfuli/follow-amazon-daily/config/config-schema.json",
  "title": "follow-amazon-daily config",
  "type": "object",
  "required": ["timezone", "language", "sources"],
  "additionalProperties": true,
  "properties": {
    "timezone": {
      "type": "string",
      "default": "America/Los_Angeles"
    },
    "language": {
      "type": "string",
      "enum": ["zh", "en", "bilingual"],
      "default": "zh",
      "description": "Digest language. zh translates English source content into natural Chinese."
    },
    "maxItemsPerSource": {
      "type": "integer",
      "minimum": 1,
      "default": 8
    },
    "delivery": {
      "type": "object",
      "description": "Optional. How the finished digest is delivered. Default is stdout (no auto-publish).",
      "additionalProperties": true,
      "properties": {
        "method": {
          "type": "string",
          "enum": ["stdout", "telegram", "email"],
          "default": "stdout"
        },
        "chatId": {
          "type": "string",
          "description": "Telegram chat id (only when method is telegram). Bot token comes from env TELEGRAM_BOT_TOKEN."
        },
        "email": {
          "type": "string",
          "description": "Recipient email (only when method is email). API key comes from env RESEND_API_KEY."
        }
      }
    },
    "frequency": {
      "type": "string",
      "enum": ["daily", "weekly"],
      "default": "daily"
    },
    "deliveryTime": {
      "type": "string",
      "description": "Local HH:MM the scheduled run should fire (used when setting up cron)."
    },
    "sources": {
      "type": "array",
      "items": { "type": "object" }
    }
  }
}
